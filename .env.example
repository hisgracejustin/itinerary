# --- Auth (NextAuth v5) ---
# Signs/encrypts the JWT session cookie. Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client. Authorized redirect URI: https://<domain>/api/auth/callback/google
# When AUTH_GOOGLE_ID is unset in dev, the login page falls back to a passwordless
# dev sign-in (any allowlisted email).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public base URL — required behind the Coolify proxy so OAuth callbacks resolve.
# AUTH_URL=https://itinerary.example.com

# Comma-separated allowlist. Only these emails may sign in.
ALLOWED_EMAILS=you@example.com

# --- Database ---
# Postgres connection string (Coolify Postgres service). Leave UNSET locally to
# use the embedded PGlite dev database under .data/pglite.
# DATABASE_URL=postgres://user:pass@host:5432/itinerary

# --- AI booking parser ---
# Poe API key used by /api/parse-booking (model claude-haiku-4.5).
POE_API_KEY=

# --- Misc ---
NEXT_PUBLIC_APP_VERSION=0.1.0
